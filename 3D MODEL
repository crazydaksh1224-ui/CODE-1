<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3D Voxel Taroumaru Plush</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background-color: #1a1a1a;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        #canvas-container {
            width: 100vw;
            height: 100vh;
            display: block;
        }
        #ui {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(20, 20, 20, 0.85);
            padding: 15px 30px;
            border-radius: 12px;
            color: white;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(8px);
            pointer-events: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            transition: opacity 0.5s;
        }
        h1 {
            margin: 0 0 5px 0;
            font-size: 1.2rem;
            color: #e59a42;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        p {
            margin: 0;
            font-size: 0.9rem;
            color: #aaaaaa;
        }
        #loading {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            font-size: 1.5rem;
            font-weight: bold;
            letter-spacing: 2px;
        }
    </style>
    <!-- Import Maps for Three.js -->
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
            }
        }
    </script>
</head>
<body>
    <div id="loading">GENERATING HIGH-RES VOXELS...</div>
    <div id="canvas-container"></div>
    <div id="ui">
        <h1>Taroumaru Voxel Model</h1>
        <p>Left Click: Rotate &nbsp;|&nbsp; Right Click: Pan &nbsp;|&nbsp; Scroll: Zoom</p>
    </div>

    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

        // Scene Setup
        const container = document.getElementById('canvas-container');
        const scene = new THREE.Scene();
        scene.background = new THREE.Color('#222225');
        scene.fog = new THREE.FogExp2('#222225', 0.015);

        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(50, 40, 60);

        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        container.appendChild(renderer.domElement);

        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
        controls.target.set(0, 20, 0);
        controls.maxPolarAngle = Math.PI / 2 + 0.1; // Don't allow going too far below ground

        // Lighting
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambientLight);

        const dirLight = new THREE.DirectionalLight(0xfffaee, 1.5);
        dirLight.position.set(30, 50, 20);
        dirLight.castShadow = true;
        dirLight.shadow.mapSize.width = 2048;
        dirLight.shadow.mapSize.height = 2048;
        dirLight.shadow.camera.near = 10;
        dirLight.shadow.camera.far = 150;
        dirLight.shadow.camera.left = -40;
        dirLight.shadow.camera.right = 40;
        dirLight.shadow.camera.top = 40;
        dirLight.shadow.camera.bottom = -40;
        dirLight.shadow.bias = -0.001;
        scene.add(dirLight);

        const fillLight = new THREE.DirectionalLight(0xaaccff, 0.4);
        fillLight.position.set(-30, 20, -20);
        scene.add(fillLight);

        // 3D Grid Helper
        const grid = new THREE.GridHelper(100, 100, 0x555555, 0x333333);
        grid.position.y = -0.5;
        scene.add(grid);

        // Voxel Generation Logic
        const ORANGE = 0xe59a42;
        const WHITE = 0xfffaee;
        const BROWN = 0x4a2e1b;
        const TRIM = 0xd3c0a8;
        const BLACK = 0x222222;

        const v = {}; // Store voxels in a hashmap to prevent overlaps

        function addVoxel(x, y, z, color) {
            v[`${x},${y},${z}`] = color;
        }

        // Generate Model (Wrapped in a timeout to allow UI rendering before heavy processing)
        setTimeout(() => {
            generateShibaInu();
            buildInstancedMesh();
            document.getElementById('loading').style.display = 'none';
        }, 100);

        function generateShibaInu() {
            // Scale and positioning constants
            const cY = 0; // base Y

            // --- 1. BODY & COAT ---
            // Y from 4 to 22. Radius roughly 12
            for(let y=4; y<=22; y++) {
                for(let x=-13; x<=13; x++) {
                    for(let z=-13; z<=13; z++) {
                        let r = (y < 8) ? 13 : 12; // slightly wider base
                        if(x*x + z*z <= r*r) {
                            // Chest opening
                            if(z > 6 && Math.abs(x) < 7) {
                                if (Math.abs(x) === 6 || (y === 22)) {
                                    addVoxel(x, y, z, TRIM); // Lapel trim
                                } else {
                                    addVoxel(x, y, z, WHITE); // White chest fur
                                }
                            } else {
                                // Coat
                                if (y === 4 || y === 5) {
                                    addVoxel(x, y, z, TRIM); // Bottom coat trim
                                } else {
                                    // Make some pattern on the coat (stylized emblem)
                                    if(z < -10 && Math.abs(x) < 4 && y > 10 && y < 16) {
                                        addVoxel(x, y, z, TRIM);
                                    } else {
                                        addVoxel(x, y, z, BROWN);
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // --- 2. SLEEVES ---
            for(let y=7; y<=14; y++) {
                // Left sleeve
                for(let x=12; x<=17; x++) {
                    for(let z=-4; z<=4; z++) {
                        if((x-12)*(x-12) + z*z <= 16) {
                            if(x === 17) addVoxel(x, y, z, TRIM);
                            else addVoxel(x, y, z, BROWN);
                        }
                    }
                }
                // Right sleeve
                for(let x=-17; x<=-12; x++) {
                    for(let z=-4; z<=4; z++) {
                        if((x+12)*(x+12) + z*z <= 16) {
                            if(x === -17) addVoxel(x, y, z, TRIM);
                            else addVoxel(x, y, z, BROWN);
                        }
                    }
                }
            }

            // --- 3. HEAD ---
            // Center around Y=30, radius 14
            for(let y=18; y<=40; y++) {
                for(let x=-16; x<=16; x++) {
                    for(let z=-16; z<=16; z++) {
                        // Oval shape for cheeks
                        let xR = x * 0.9;
                        let dist = xR*xR + (y-30)*(y-30) + z*z;
                        if(dist <= 196) {
                            // Upper half orange, lower half white
                            if (y >= 32) addVoxel(x, y, z, ORANGE);
                            else addVoxel(x, y, z, WHITE);

                            // Eyebrow spots
                            if (y === 35 && z > 10 && Math.abs(x) > 4 && Math.abs(x) < 8) {
                                addVoxel(x, y, z, WHITE);
                                addVoxel(x, y+1, z, WHITE);
                            }
                        }
                    }
                }
            }

            // --- 4. SNOUT ---
            for(let y=23; y<=29; y++) {
                for(let x=-7; x<=7; x++) {
                    for(let z=12; z<=19; z++) {
                        let dist = x*x + (y-26)*(y-26) + (z-13)*(z-13);
                        if(dist <= 40) {
                            addVoxel(x, y, z, WHITE);
                        }
                    }
                }
            }

            // Nose
            addVoxel(0, 29, 19, BLACK);
            addVoxel(-1, 29, 19, BLACK);
            addVoxel(1, 29, 19, BLACK);
            addVoxel(0, 28, 19, BLACK);

            // Smile (W shape)
            for(let x=-4; x<=4; x++) {
                let y = 25;
                if(Math.abs(x) === 2 || Math.abs(x) === 3) y = 24;
                if(Math.abs(x) === 4) y = 25;
                addVoxel(x, y, 18, BLACK);
            }

            // Eyes
            for(let y=31; y<=33; y++) {
                for(let x=6; x<=7; x++) addVoxel(x, y, 13, BLACK);
                for(let x=-7; x<=-6; x++) addVoxel(x, y, 13, BLACK);
            }

            // --- 5. EARS ---
            for(let y=38; y<=49; y++) {
                let width = 49 - y; // Tapares as it goes up
                
                // Left Ear
                for(let x = 7; x <= 7 + width; x++) {
                    for(let z = -3; z <= 2; z++) {
                        let dz = Math.abs(z);
                        if(x - 7 + dz <= width) {
                            if(z > -1 && x < 7 + width - 1) addVoxel(x, y, z, WHITE); // inner ear
                            else addVoxel(x, y, z, ORANGE);
                        }
                    }
                }

                // Right Ear
                for(let x = -7 - width; x <= -7; x++) {
                    for(let z = -3; z <= 2; z++) {
                        let dz = Math.abs(z);
                        if(Math.abs(x + 7) + dz <= width) {
                            if(z > -1 && x > -7 - width + 1) addVoxel(x, y, z, WHITE); // inner ear
                            else addVoxel(x, y, z, ORANGE);
                        }
                    }
                }
            }

            // --- 6. HEADBAND (Towel) ---
            // Wraps around the forehead (Y 37 to 41)
            for(let y=37; y<=41; y++) {
                for(let x=-17; x<=17; x++) {
                    for(let z=-17; z<=17; z++) {
                        let xR = x * 0.9;
                        let distToCenter = xR*xR + (y-30)*(y-30) + z*z;
                        
                        // Create a band hovering just outside the head radius
                        if(distToCenter >= 190 && distToCenter <= 250) {
                            // Make it thick and twisted
                            let twist = Math.sin(x * 0.5) * 2;
                            if(Math.abs(y - 39 + twist) <= 2) {
                                addVoxel(x, y, z, WHITE);
                            }
                        }
                    }
                }
            }
            // Headband Knot (Front Center)
            for(let y=38; y<=44; y++) {
                for(let x=-6; x<=6; x++) {
                    for(let z=12; z<=16; z++) {
                        let knotDist = (x)*(x) + (y-41)*(y-41) + (z-13)*(z-13);
                        if(knotDist <= 16) {
                            addVoxel(x, y, z, WHITE);
                        }
                        // Flaps
                        if((x > 3 || x < -3) && y < 40 && knotDist <= 25) {
                            addVoxel(x, y, z, WHITE);
                        }
                    }
                }
            }

            // --- 7. PAWS ---
            // Front Left
            createPaw(6, 0, 10);
            // Front Right
            createPaw(-6, 0, 10);
            // Back Left
            createPaw(9, 0, -8);
            // Back Right
            createPaw(-9, 0, -8);

            // --- 8. TAIL (Curled over back) ---
            for(let y=12; y<=20; y++) {
                for(let x=-4; x<=4; x++) {
                    for(let z=-17; z<=-12; z++) {
                        let tDist = x*x + (y-16)*(y-16) + (z+14)*(z+14);
                        if(tDist <= 16) {
                            if(y > 17) addVoxel(x, y, z, WHITE); // White tip
                            else addVoxel(x, y, z, ORANGE);
                        }
                    }
                }
            }
        }

        function createPaw(cX, cY, cZ) {
            // Y from 0 to 5
            for(let y=cY; y<=cY+5; y++) {
                for(let x=cX-4; x<=cX+4; x++) {
                    for(let z=cZ-4; z<=cZ+4; z++) {
                        if((x-cX)*(x-cX) + (y-(cY+2))*(y-(cY+2)) + (z-cZ)*(z-cZ) <= 18) {
                            // Flatter bottom
                            if(y >= cY) addVoxel(x, y, z, WHITE);
                        }
                    }
                }
            }
        }

        let instancedMesh;
        function buildInstancedMesh() {
            const voxelKeys = Object.keys(v);
            const count = voxelKeys.length;

            // Geometry (slightly smaller than 1 to give voxel grid gap effect)
            const geometry = new THREE.BoxGeometry(0.95, 0.95, 0.95);
            
            // Material (Slightly rough for plush appearance)
            const material = new THREE.MeshStandardMaterial({ 
                color: 0xffffff,
                roughness: 0.9,
                metalness: 0.0,
            });

            instancedMesh = new THREE.InstancedMesh(geometry, material, count);
            instancedMesh.castShadow = true;
            instancedMesh.receiveShadow = true;

            const dummy = new THREE.Object3D();
            const colorObj = new THREE.Color();

            for(let i = 0; i < count; i++) {
                const key = voxelKeys[i];
                const [x, y, z] = key.split(',').map(Number);
                const hexColor = v[key];

                dummy.position.set(x, y, z);
                dummy.updateMatrix();

                instancedMesh.setMatrixAt(i, dummy.matrix);
                
                colorObj.setHex(hexColor);
                instancedMesh.setColorAt(i, colorObj);
            }

            // Ensure matrices and colors are updated
            instancedMesh.instanceMatrix.needsUpdate = true;
            if(instancedMesh.instanceColor) instancedMesh.instanceColor.needsUpdate = true;

            scene.add(instancedMesh);
        }

        // Window Resize Handler
        window.addEventListener('resize', onWindowResize, false);
        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        // Animation Loop
        const clock = new THREE.Clock();
        function animate() {
            requestAnimationFrame(animate);
            
            // Smoothly auto-rotate slowly if user isn't interacting
            controls.update();

            // Very subtle idle floating animation
            if (instancedMesh) {
                const time = clock.getElapsedTime();
                instancedMesh.position.y = Math.sin(time * 2) * 0.5;
            }

            renderer.render(scene, camera);
        }

        animate();
    </script>
</body>
</html>
