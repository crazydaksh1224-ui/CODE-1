<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Akasha Economic Simulator</title>
    <!-- Importing Genshin-like elegant fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Nunito:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Genshin Impact Core Theme Colors */
            --bg-color: #1a1e29;
            --panel-bg: rgba(30, 36, 50, 0.75);
            --panel-border: #d4af37;
            --gold-light: #fcd34d;
            --gold-dark: #b48608;
            --text-main: #faf5eb;
            --text-muted: #a1a1aa;
            --highlight: #60a5fa;

            /* Dynamic City Animation Variables (Default State) */
            --sky-top: #1e3a8a;
            --sky-bottom: #7dd3fc;
            --sun-y: 100px;
            --sun-color: #fde047;
            --sun-glow: rgba(253, 224, 71, 0.5);
            --moon-opacity: 0;
            --star-opacity: 0;
            --cloud-color: #ffffff;
            --cloud-opacity: 0.8;
            --mountain-color: #475569;
            --build-bg: #334155;
            --build-fg: #1e293b;
            --window-color: #fde047;
            --window-glow: 0 0 10px rgba(253, 224, 71, 0.6);
            --pollution-opacity: 0;
            --pollution-color: #854d0e;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
        }

        body {
            background-color: var(--bg-color);
            background-image: 
                radial-gradient(circle at top right, rgba(30, 58, 138, 0.3) 0%, transparent 50%),
                radial-gradient(circle at bottom left, rgba(180, 134, 8, 0.1) 0%, transparent 50%);
            color: var(--text-main);
            font-family: 'Nunito', sans-serif;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            overflow-x: hidden;
        }

        /* Widget Container */
        .widget-container {
            width: 100%;
            max-width: 900px;
            background: var(--panel-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(212, 175, 55, 0.4);
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 
                        inset 0 0 20px rgba(212, 175, 55, 0.1);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 20px;
            padding: 30px;
        }

        /* Elaborate Corner Decorations */
        .widget-container::before, .widget-container::after {
            content: '✦';
            position: absolute;
            color: var(--gold-light);
            font-size: 24px;
            opacity: 0.8;
        }
        .widget-container::before { top: 10px; left: 15px; }
        .widget-container::after { top: 10px; right: 15px; }

        .corner-bottom-left, .corner-bottom-right {
            position: absolute;
            color: var(--gold-light);
            font-size: 24px;
            opacity: 0.8;
            bottom: 10px;
        }
        .corner-bottom-left { left: 15px; }
        .corner-bottom-right { right: 15px; }

        /* Header Styling */
        header {
            text-align: center;
            position: relative;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
        }

        h1 {
            font-family: 'Cinzel', serif;
            font-size: 2rem;
            color: var(--gold-light);
            letter-spacing: 2px;
            text-transform: uppercase;
            text-shadow: 0 0 15px rgba(252, 211, 77, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }

        h1::before, h1::after {
            content: '';
            display: block;
            width: 50px;
            height: 2px;
            background: linear-gradient(to right, transparent, var(--gold-light), transparent);
        }

        .subtitle {
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-top: 5px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* City Display SVG Area */
        .city-view-wrapper {
            position: relative;
            width: 100%;
            height: 250px;
            border-radius: 8px;
            border: 2px solid rgba(212, 175, 55, 0.5);
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            background: #000;
        }

        .city-svg {
            width: 100%;
            height: 100%;
            display: block;
        }

        /* SVG Dynamic Transitions */
        .sky-grad-top, .sky-grad-bottom, 
        .sun-moon, .mountain, 
        .building-bg, .building-fg, 
        .window, .cloud, .pollution-layer {
            transition: all 1.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Animations */
        @keyframes drift {
            0% { transform: translateX(-5%); }
            50% { transform: translateX(5%); }
            100% { transform: translateX(-5%); }
        }

        @keyframes twinkle {
            0%, 100% { opacity: 0.2; }
            50% { opacity: 1; }
        }

        .cloud-group { animation: drift 20s infinite ease-in-out; }
        .star { animation: twinkle 3s infinite ease-in-out; }
        .star:nth-child(even) { animation-duration: 4s; animation-delay: 1s; }

        /* State Info Panel */
        .state-panel {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 6px;
            padding: 20px;
            text-align: center;
            position: relative;
            min-height: 120px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .state-title {
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            color: var(--gold-light);
            margin-bottom: 10px;
            letter-spacing: 1px;
            transition: color 0.5s;
        }

        .state-desc {
            font-size: 0.95rem;
            line-height: 1.5;
            color: var(--text-main);
        }

        /* Controls Section */
        .controls-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 10px;
        }

        /* Interactive Card */
        .control-card {
            background: linear-gradient(145deg, rgba(30, 41, 59, 0.6), rgba(15, 23, 42, 0.8));
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: 8px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
        }

        .control-card:hover {
            transform: translateY(-2px);
            border-color: var(--gold-light);
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.15);
        }

        .card-icon {
            font-size: 24px;
            color: var(--gold-light);
            margin-bottom: 10px;
            text-shadow: 0 0 10px rgba(252, 211, 77, 0.5);
        }

        .card-title {
            font-family: 'Cinzel', serif;
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 5px;
            text-transform: uppercase;
            text-align: center;
        }

        .card-value {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--gold-light);
            margin-bottom: 15px;
            text-shadow: 0 0 10px rgba(252, 211, 77, 0.3);
            font-family: 'Courier New', monospace;
        }

        /* Custom Slider (Genshin Style) */
        input[type=range] {
            -webkit-appearance: none;
            width: 100%;
            background: transparent;
        }

        input[type=range]:focus {
            outline: none;
        }

        input[type=range]::-webkit-slider-runnable-track {
            width: 100%;
            height: 6px;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
            border: 1px solid rgba(212, 175, 55, 0.2);
        }

        input[type=range]::-webkit-slider-thumb {
            height: 20px;
            width: 20px;
            border-radius: 50%;
            background: var(--gold-light);
            cursor: pointer;
            -webkit-appearance: none;
            margin-top: -8px;
            box-shadow: 0 0 10px var(--gold-light), inset 0 0 5px #fff;
            border: 2px solid #fff;
            transform: rotate(45deg); /* Diamond shape */
            transition: transform 0.1s, box-shadow 0.1s;
        }

        input[type=range]::-webkit-slider-thumb:hover {
            transform: rotate(45deg) scale(1.2);
            box-shadow: 0 0 15px var(--gold-light), inset 0 0 8px #fff;
        }

        input[type=range]::-moz-range-track {
            width: 100%;
            height: 6px;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
            border: 1px solid rgba(212, 175, 55, 0.2);
        }

        input[type=range]::-moz-range-thumb {
            height: 20px;
            width: 20px;
            border-radius: 50%;
            background: var(--gold-light);
            cursor: pointer;
            box-shadow: 0 0 10px var(--gold-light), inset 0 0 5px #fff;
            border: 2px solid #fff;
            transform: rotate(45deg);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .controls-container {
                grid-template-columns: 1fr;
            }
            .widget-container {
                padding: 20px;
            }
            h1 {
                font-size: 1.5rem;
            }
        }
    </style>
</head>
