    /**
     * Categorize a 0-100 value into Low (L), Mid (M), High (H)
     */
    function getLevel(val) {
        if (val <= 33) return 'L';
        if (val <= 66) return 'M';
        return 'H';
    }

    /**
     * Map the 27 possible combinations of (L, M, H) to the 12 States
     */
    const logicMatrix = {
        // L Income
        'L-L-L': 1, 'L-L-M': 12, 'L-L-H': 2,
        'L-M-L': 1, 'L-M-M': 12, 'L-M-H': 2,
        'L-H-L': 6, 'L-H-M': 6,  'L-H-H': 8,

        // M Income
        'M-L-L': 1, 'M-L-M': 12, 'M-L-H': 2,
        'M-M-L': 10,'M-M-M': 12, 'M-M-H': 9,
        'M-H-L': 4, 'M-H-M': 10, 'M-H-H': 3,

        // H Income
        'H-L-L': 5, 'H-L-M': 5,  'H-L-H': 7,
        'H-M-L': 4, 'H-M-M': 11, 'H-M-H': 3,
        'H-H-L': 4, 'H-H-M': 11, 'H-H-H': 3
    };

    /**
     * Update the SVG UI CSS Variables based on state theme
     */
    function applyTheme(theme) {
        root.style.setProperty('--sky-top', theme.skyTop);
        root.style.setProperty('--sky-bottom', theme.skyBottom);
        root.style.setProperty('--sun-y', theme.sunY);
        root.style.setProperty('--sun-color', theme.sunColor);
        root.style.setProperty('--moon-opacity', theme.moonOpacity);
        root.style.setProperty('--star-opacity', theme.starOpacity);
        root.style.setProperty('--cloud-color', theme.cloudColor);
        root.style.setProperty('--cloud-opacity', theme.cloudOpacity);
        root.style.setProperty('--mountain-color', theme.mountainColor);
        root.style.setProperty('--build-bg', theme.buildBg);
        root.style.setProperty('--build-fg', theme.buildFg);
        root.style.setProperty('--window-color', theme.windowColor);
        root.style.setProperty('--pollution-opacity', theme.pollutionOpacity);
        root.style.setProperty('--pollution-color', theme.pollutionColor);
        
        // Add text flash effect
        stateNameEl.style.color = "#ffffff";
        setTimeout(() => {
            stateNameEl.style.color = "var(--gold-light)";
        }, 300);
    }

    /**
     * Main evaluation function triggered on slider change
     */
    function evaluateEconomy() {
        const inc = parseInt(slIncome.value);
        const corp = parseInt(slCorp.value);
        const spend = parseInt(slSpend.value);

        // Update Text displays
        valIncome.innerText = inc;
        valCorp.innerText = corp;
        valSpend.innerText = spend;

        // Determine Levels
        const comboKey = `${getLevel(inc)}-${getLevel(corp)}-${getLevel(spend)}`;
        
        // Find corresponding state (fallback to 12 if somehow undefined)
        const stateId = logicMatrix[comboKey] || 12;

        if (currentStateIndex !== stateId) {
            currentStateIndex = stateId;
            const stateObj = statesData[stateId];
            
            // Update Text
            stateNameEl.innerText = `✦ ${stateObj.name} ✦`;
            stateDescEl.innerText = stateObj.desc;
            
            // Update Visuals
            applyTheme(stateObj.theme);
        }
    }

    // Event Listeners for smooth real-time update
    slIncome.addEventListener('input', evaluateEconomy);
    slCorp.addEventListener('input', evaluateEconomy);
    slSpend.addEventListener('input', evaluateEconomy);

    // Initialize
    evaluateEconomy();

</script>

