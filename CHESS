        }

        // Set state for level selected
        function selectLevel(levelNum) {
            activeLevel = levelNum;
            document.getElementById('level-badge').innerText = `LEVEL ${levelNum}`;
            
            // Assign random AI Tactic/Personality for this level run
            const randomTactic = PERSONALITIES[Math.floor(Math.random() * PERSONALITIES.length)];
            aiPersonality = randomTactic;
            
            document.getElementById('ai-tactic-name').innerText = randomTactic.name;
            
            // Close modal with style
            document.getElementById('welcome-modal').classList.add('hidden');
            document.getElementById('main-content').classList.remove('blur-sm');

            // Reset engine with the selected configuration
            resetGame();

            showToast("Lesson Initialized", `Welcome to Level ${levelNum}! You are playing against "${randomTactic.name}".`);
        }

        function showWelcomeScreen() {
            document.getElementById('welcome-modal').classList.remove('hidden');
            document.getElementById('main-content').classList.add('blur-sm');
        }

        // Render Board logic
        function initializeBoard() {
            const boardEl = document.getElementById('board');
            boardEl.innerHTML = '';

            for (let row = 0; row < 8; row++) {
                for (let col = 0; col < 8; col++) {
                    const squareDiv = document.createElement('div');
                    const isDark = (row + col) % 2 === 1;
                    const file = String.fromCharCode(97 + col);
                    const rank = 8 - row;
                    const squareCoord = `${file}${rank}`;

                    squareDiv.id = `sq-${squareCoord}`;
                    squareDiv.className = `w-full h-full relative flex items-center justify-center cursor-pointer transition-all duration-150 ${isDark ? 'square-dark' : 'square-light'}`;
                    
                    // Add click action
                    squareDiv.addEventListener('click', () => handleSquareClick(squareCoord));
                    
                    boardEl.appendChild(squareDiv);
                }
            }
            updateBoardDisplay();
        }

        function updateBoardDisplay() {
            const boardState = game.board();
            
            for (let row = 0; row < 8; row++) {
                for (let col = 0; col < 8; col++) {
                    const file = String.fromCharCode(97 + col);
                    const rank = 8 - row;
                    const squareCoord = `${file}${rank}`;
                    const squareDiv = document.getElementById(`sq-${squareCoord}`);
                    
                    // Clear previous highlights or items (preserve helper classes)
                    squareDiv.innerHTML = '';
                    squareDiv.classList.remove('square-selected');
                    squareDiv.classList.remove('square-dest');

                    const piece = boardState[row][col];
                    if (piece) {
                        // Generate hand-drawn monochrome piece SVG
                        const pieceSymbol = piece.color === 'w' ? piece.type.toUpperCase() : piece.type.toLowerCase();
                        const pieceSvg = SVG_PIECES[pieceSymbol];
                        if (pieceSvg) {
                            squareDiv.innerHTML = `<div class="w-[82%] h-[82%] flex items-center justify-center transform active:scale-95 transition-transform duration-75">${pieceSvg}</div>`;
                        }
                    }
                }
            }

            // Highlight selected square if active
            if (selectedSquare) {
                const selDiv = document.getElementById(`sq-${selectedSquare}`);
                if (selDiv) selDiv.classList.add('square-selected');

                // Display eligible landing/destination markers
                const moves = game.moves({ square: selectedSquare, verbose: true });
                moves.forEach(m => {
                    const destDiv = document.getElementById(`sq-${m.to}`);
                    if (destDiv) destDiv.classList.add('square-dest');
                });
            }
        }

        // Square clicked event handling
        function handleSquareClick(square) {
            if (game.game_over()) {
                showToast("Game Finished", "This lesson matches is over. Reset the board to try again.");
                return;
            }

            // Don't allow clicking while computer's turn
            if (game.turn() === 'b') {
                return;
            }

            const clickedPiece = game.get(square);

            if (selectedSquare === square) {
                // Clicking same square cancels choice
                selectedSquare = null;
                updateBoardDisplay();
                return;
            }

            // If a friendly piece was clicked, select it immediately
            if (clickedPiece && clickedPiece.color === 'w') {
                selectedSquare = square;
                updateBoardDisplay();
                return;
            }

            // Attempt to perform a movement
            if (selectedSquare) {
                const moves = game.moves({ square: selectedSquare, verbose: true });
                const validMove = moves.find(m => m.to === square);

                if (validMove) {
                    // Try to execute movement
                    const moveResult = game.move({
                        from: selectedSquare,
                        to: square,
                        promotion: 'q' // Auto promote to Queen for simplicity
                    });

                    if (moveResult) {
                        selectedSquare = null;
                        totalMovesCounter++;
                        document.getElementById('move-counter').innerText = `Moves: ${totalMovesCounter}`;
                        
                        updateBoardDisplay();
                        
                        // Populate interactive card before opponent reacts
                        generateConceptCardForMove(totalMovesCounter, moveResult);

                        // Trigger bot response after a brief delay
                        document.getElementById('game-status').innerText = "Bot is thinking...";
                        setTimeout(triggerBotMove, 800);
                    }
                } else {
                    // Invalid destination, clear selection
                    selectedSquare = null;
                    updateBoardDisplay();
                }
            }
        }

        // Enemy Adaptive AI Tactic Logic
        function triggerBotMove() {
            if (game.game_over()) {
                handleGameOverState();
                return;
            }

            const aiMove = computeBestMove();
            if (aiMove) {
                game.move(aiMove);
                updateBoardDisplay();
                document.getElementById('game-status').innerText = "Your move";

                // Readjust game status text if check
                if (game.in_check()) {
                    document.getElementById('game-status').innerText = "Check!";
                    showToast("⚠️ Under Attack", "Your king is checked. Block the attack, capture the attacker, or move away!");
                }
            }

            if (game.game_over()) {
                handleGameOverState();
            }
        }

        // Positional Evaluation Tables for Basic AI search
        const pieceValues = { p: 10, r: 50, n: 30, b: 30, q: 90, k: 9000 };

        // Simple Minimax search algorithm with positional weight tweaks based on level and selected personality
        function computeBestMove() {
            const possibleMoves = game.moves({ verbose: true });
            if (possibleMoves.length === 0) return null;

            // Introduce occasional variation/randomness to simulate "human-like" tactic changes
            if (Math.random() < 0.15) {
                return possibleMoves[Math.floor(Math.random() * possibleMoves.length)];
            }

            let bestMove = null;
            let bestValue = -999999;

            // Simple 2-ply search (evaluates optimal replies)
            for (let i = 0; i < possibleMoves.length; i++) {
                const move = possibleMoves[i];
                game.move(move);
                
                let boardVal = evaluateBoard();
                // If checking the opponent, boost weight depending on tactic
                if (game.in_check()) {
                    boardVal += (5 * (aiPersonality ? aiPersonality.dangerFactor : 1));
                }

                // Opponent counter-move analysis
                let worstOpponentReply = 999999;
                const replies = game.moves({ verbose: true });
                for (let j = 0; j < replies.length; j++) {
                    game.move(replies[j]);
                    const oppVal = evaluateBoard();
                    if (oppVal < worstOpponentReply) worstOpponentReply = oppVal;
                    game.undo();
                }

                game.undo();

                // If no replies, opponent is in checkmate or stalemate
                const netValue = replies.length === 0 ? boardVal + 10000 : boardVal - worstOpponentReply;

                if (netValue > bestValue) {
                    bestValue = netValue;
                    bestMove = move;
                }
            }

            return bestMove || possibleMoves[0];
        }

        function evaluateBoard() {
            const board = game.board();
            let score = 0;

            for (let r = 0; r < 8; r++) {
                for (let c = 0; c < 8; c++) {
                    const cell = board[r][c];
                    if (cell) {
                        let val = pieceValues[cell.type];
                        
                        // Apply personality bias to specific piece roles
                        if (aiPersonality) {
                            if (cell.type === 'p') {
                                // Add value based on chosen pawn table
                                val += aiPersonality.pawnTable[r][c];
                            }
                            if (cell.type === 'q' && aiPersonality.name === "The Sneaky Tactician") {
                                val += 5; // Queens are valued slightly higher to encourage queen activity
                            }
                        }

                        // Positive score for bot (Black), negative for player (White)
                        if (cell.color === 'b') {
                            score += val;
                        } else {
                            score -= val;
                        }
                    }
                }
            }
            return score;
        }

        // Construct Interactive Feed Cards dynamically
        function generateConceptCardForMove(moveIndex, playerMoveObj) {
            const feedEl = document.getElementById('tutorial-feed');
            
            // Determine which tutorial deck is active
            const deck = DYNAMIC_TUTORIALS[activeLevel] || DYNAMIC_TUTORIALS[1];
            
            // Match based on move turn, fallback to a looping concept card
            let cardData = deck.find(c => c.trigger === moveIndex);
            
            // If no specific card is triggered, generate a context-aware strategy card based on player move
            if (!cardData) {
                cardData = generateContextAwareCard(playerMoveObj);
            }

            // Create horizontal hand-drawn styled card structure
            const cardMarkup = `
                <div class="bg-white border-2 border-black p-4 sketchy-border card-shadow transition-all duration-300 transform hover:-translate-y-1">
                    <div class="flex items-start space-x-3">
                        <div class="text-3xl p-1 bg-neutral-100 rounded border border-black inline-block">
                            ${cardData.icon}
                        </div>
                        <div class="flex-grow">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-1">
                                <h3 class="font-bold text-lg handwritten text-black">${cardData.title}</h3>
                                <span class="monospace text-[10px] bg-black text-white px-2 py-0.5 rounded">Move ${moveIndex} Concept</span>
                            </div>
                            <h4 class="text-xs font-bold uppercase tracking-wider monospace text-gray-400 mb-2">${cardData.subtitle}</h4>
                            <p class="text-sm text-gray-700 font-serif leading-relaxed mb-3">
                                ${cardData.description}
                            </p>
                            <div class="border-t border-dashed border-neutral-300 pt-3">
                                <span class="monospace text-xs font-bold text-gray-500 block mb-1">💡 Suggested Variations to test:</span>
                                <ul class="list-disc pl-4 space-y-1">
                                    ${cardData.variations.map(v => `<li class="text-xs text-gray-600 font-serif">${v}</li>`).join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            // Insert at the top of the stream so player sees newest move on top
            feedEl.insertAdjacentHTML('afterbegin', cardMarkup);
            feedEl.scrollTop = 0;
        }

        // Generate contextual conceptual card when database trigger ends
        function generateContextAwareCard(moveObj) {
            const pieceNames = { p: 'Pawn', r: 'Rook', n: 'Knight', b: 'Bishop', q: 'Queen', k: 'King' };
            const fromSq = moveObj.from.toUpperCase();
            const toSq = moveObj.to.toUpperCase();
            const pieceName = pieceNames[moveObj.piece];

            let title = `Strategic Move: ${pieceName} to ${toSq}`;
            let subtitle = "Positional Readjustment";
            let description = `You moved your ${pieceName} from ${fromSq} to ${toSq}. This reshapes your spatial coordination. Evaluate how this square affects your central coverage and pawn structures. Remember, every move weakens the square your piece just left behind.`;
            let icon = "♟️";
            let variations = [
                "Consider structural reinforcement of this piece.",
                "Ensure diagonals behind this piece remain guarded from enemy counters."
            ];

            if (moveObj.captured) {
                const capturedPieceName = pieceNames[moveObj.captured];
                title = `Tactical Capture: ${pieceName} takes ${capturedPieceName}`;
                subtitle = "Material Exchange & Trade Assessment";
                icon = "⚔️";
                description = `Brilliant! Your ${pieceName} on ${fromSq} successfully captured the enemy ${capturedPieceName} on ${toSq}. Think carefully about this trade: Was it an even exchange, or did you gain material superiority? Analyze if this capture opened up any attack vectors for your opponent's long-range bishops.`;
                variations = [
                    "Check if the capturing piece is now unprotected ('hanging').",
                    "Scan for adjacent enemy forks that might arise from this open space."
                ];
            } else if (moveObj.piece === 'p') {
                title = `Pawn Push: Advancing the Frontline`;
                subtitle = "Pawn Chains and Space Control";
                icon = "🧱";
                description = `You advanced your pawn to ${toSq}. Pawns cannot move backwards—this choice is permanent. You have claimed spatial leverage but left weaknesses in adjacent squares (outposts for opponent knights).`;
                variations = [
                    "Form a strong diagonal pawn chain to block enemy bishop vectors.",
                    "Look for opportunities to execute pawn breaks to open files."
                ];
            } else if (moveObj.piece === 'k') {
                title = `King Position: Defense and Outposts`;
                subtitle = "Guarding the Sovereign";
                icon = "👑";
                description = `You adjusted your King's coordinate to ${toSq}. In the middle game, active King positions are generally highly vulnerable. Keep your king secured until late endgame, where it transforms into an active fighting unit.`;
                variations = [
                    "Prepare shelter pawns in front of the king.",
                    "Keep rooks joined along the bottom rank to support escape coordinates."
                ];
            }

            return { title, subtitle, icon, description, variations };
        }

        // Suggest conceptual move
        function requestHint() {
            const moves = game.moves({ verbose: true });
            if (moves.length === 0) return;

            // Simple search to suggest top tactical move
            let bestHint = moves[0];
            let maxScore = -99999;
            
            moves.forEach(m => {
                let score = 0;
                if (m.captured) score += 10;
                if (m.piece === 'n' || m.piece === 'b') score += 2; // minor piece development
                if (m.san.includes('+')) score += 5; // checks are active
                
                if (score > maxScore) {
                    maxScore = score;
                    bestHint = m;
                }
            });

            showToast("Conceptual Hint", `The academy recommends exploring the move: ${bestHint.san} (${bestHint.from.toUpperCase()} to ${bestHint.to.toUpperCase()}). Try assessing its impact!`);
        }

        // Dynamic Position Evaluation
        function explainCurrentBoard() {
            const evaluation = evaluateBoard();
            let analysis = "";

            if (evaluation === 0) {
                analysis = "The position is dynamically balanced. Material is completely equal. Focus on piece activity.";
            } else if (evaluation < 0) {
                analysis = "You have positional or material superiority! Leverage your spatial advantage and force trades to simplify.";
            } else {
                analysis = "The opponent holds a positional edge. Tighten your defenses, coordinate your knights, and watch for forks.";
            }

            showToast("Strategic Assessment", analysis);
        }

        // Game Over modal handlers
        function handleGameOverState() {
            let title = "Match Over";
            let msg = "The game ended in a draw or stalemate.";

            if (game.in_checkmate()) {
                if (game.turn() === 'b') {
                    title = "🎉 Victory!";
                    msg = "Splendid job! You delivered a checkmate and successfully applied the concepts.";
                } else {
                    title = "💀 Defeat";
                    msg = "Checkmate! The computer caught you in a tactical pin. Try resetting to try again.";
                }
            }

            showToast(title, msg);
            document.getElementById('game-status').innerText = title;
        }

        // Reset game to fresh state
        function resetGame() {
            game = new Chess();
            selectedSquare = null;
            totalMovesCounter = 0;
            document.getElementById('move-counter').innerText = `Moves: 0`;
            document.getElementById('game-status').innerText = "Your move";
            
            // Clear current cards feed
            document.getElementById('tutorial-feed').innerHTML = '';

            // Render basic first concept card
            generateConceptCardForMove(0, { from: '?', to: '?', piece: 'p' });

            initializeBoard();
        }

        // Custom Toast Engine
        function showToast(title, message) {
            const toast = document.getElementById('toast-notification');
            document.getElementById('toast-title').innerText = title;
            document.getElementById('toast-body').innerText = message;

            // Animate toast entry
            toast.classList.remove('translate-y-24', 'opacity-0');
            
            // Auto dismiss after 6 seconds
            setTimeout(dismissToast, 6000);
        }

        function dismissToast() {
            const toast = document.getElementById('toast-notification');
            toast.classList.add('translate-y-24', 'opacity-0');
        }
