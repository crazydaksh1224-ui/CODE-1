<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notion Chess Academy</title>
    <!-- Tailwind CSS for rich responsive utility layout -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Chess.js for flawless chess mechanics validation -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"></script>
    <!-- Google Fonts for a perfect mix of Hand-drawn and Academic Minimalist Serif -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Architects+Daughter&family=Courier+Prime:ital,wght@0,400;0,700;1,400;1,700&family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">
    
    <style>
        /* CSS Variables matching Notion light neutral theme with sketchy feel */
        :root {
            --bg-notion: #fbfbfa;
            --text-notion: #37352f;
            --border-notion: #000000;
            --card-notion: #ffffff;
            --accent-notion: #2eaadc;
        }

        body {
            font-family: 'Lora', Georgia, serif;
            background-color: var(--bg-notion);
            color: var(--text-notion);
            background-image: 
                radial-gradient(#e5e5e5 1px, transparent 1px), 
                radial-gradient(#e5e5e5 1px, #fbfbfa 1px);
            background-size: 24px 24px;
            background-position: 0 0, 12px 12px;
        }

        .handwritten {
            font-family: 'Architects Daughter', cursive;
        }

        .monospace {
            font-family: 'Courier Prime', monospace;
        }

        /* Sketchy/Hand-drawn SVG filter effect */
        .sketchy-border {
            filter: url(#rough-edge);
            border: 2px solid var(--border-notion);
        }

        .sketchy-piece {
            filter: url(#rough-edge-subtle);
        }

        /* Chess Board Styles */
        .board-grid {
            display: grid;
            grid-template-columns: repeat(8, minmax(0, 1fr));
            grid-template-rows: repeat(8, minmax(0, 1fr));
            aspect-ratio: 1;
        }

        .square-light {
            background-color: #ffffff;
        }

        .square-dark {
            background-color: #e5e5e5;
            background-image: repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(0,0,0,0.04) 5px, rgba(0,0,0,0.04) 10px);
        }

        .square-selected {
            box-shadow: inset 0 0 0 4px #000000;
            background-color: rgba(0, 0, 0, 0.08) !important;
        }

        .square-dest {
            position: relative;
        }

        .square-dest::after {
            content: '';
            position: absolute;
            width: 24%;
            height: 24%;
            background-color: var(--text-notion);
            border-radius: 50%;
            top: 38%;
            left: 38%;
            opacity: 0.6;
        }

        /* Scrollbar styles to match Notion minimal look */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #d3d1cb;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #aeaca6;
        }

        /* Custom sketchy button styles */
        .sketchy-btn {
            position: relative;
            background: #ffffff;
            border: 2px solid #000000;
            transition: transform 0.1s ease, box-shadow 0.1s ease;
            box-shadow: 2px 2px 0px #000000;
        }

        .sketchy-btn:hover {
            transform: translate(-1px, -1px);
            box-shadow: 3px 3px 0px #000000;
        }

        .sketchy-btn:active {
            transform: translate(1px, 1px);
            box-shadow: 1px 1px 0px #000000;
        }

        .card-shadow {
            box-shadow: 4px 4px 0px #000000;
        }

        /* Smooth blur transition */
        .blur-transition {
            transition: filter 0.4s ease;
        }
    </style>
</head>
<body class="min-h-screen p-2 md:p-6 flex flex-col justify-between">

    <!-- SVG Roughness Filters for generating genuine pencil-sketch borders -->
    <svg style="visibility: hidden; position: absolute;" width="0" height="0" xmlns="http://www.w3.org/2000/svg">
        <!-- High roughness for containers and cards -->
        <filter id="rough-edge">
            <feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="3" result="noise" />
            <feDisplacementMap in="SourceGraphic" in2="noise" scale="3.5" xChannelSelector="R" yChannelSelector="G" />
        </filter>
        <!-- Soft roughness for chess pieces & icons to prevent illegibility -->
        <filter id="rough-edge-subtle">
            <feTurbulence type="fractalNoise" baseFrequency="0.05" numOctaves="2" result="noise" />
