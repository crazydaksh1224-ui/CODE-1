<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notion Style Redirect Button</title>
    <style>
        /* =========================================================
           Notion Style Monotone Theme & Reset
           ========================================================= */
        :root {
            --notion-bg: #ffffff;
            --notion-text: #2f3437;
            --notion-text-light: #787c7e;
            --notion-border: #e1e4e8;
            --transition-warp: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body, html {
            height: 100%;
            background-color: var(--notion-bg);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, "Apple Color Emoji", Arial, sans-serif, "Segoe UI Emoji", "Segoe UI Symbol";
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            color: var(--notion-text);
        }

        /* =========================================================
           Page Loading Bar (Mimics Chrome loading)
           ========================================================= */
        #page-loader {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background-color: var(--notion-text);
            width: 0%;
            z-index: 9999;
            transition: width 1.2s cubic-bezier(0.2, 0.8, 0.2, 1);
            opacity: 1;
        }

        /* =========================================================
           The Central Button
           ========================================================= */
        .notion-btn {
            position: relative;
            background-color: var(--notion-bg);
            color: var(--notion-text);
            border: 1px solid var(--notion-border);
            border-radius: 4px; /* Notion's standard slight rounding */
            padding: 12px 28px;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            outline: none;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
            transition: var(--transition-warp);
            display: flex;
            justify-content: center;
            align-items: center;
            min-width: 160px;
            height: 44px;
        }

        .btn-text {
            display: flex;
            align-items: center;
            gap: 8px;
            transition: opacity 0.3s, transform 0.3s;
        }

        /* SVG Play Icon */
        .btn-text svg {
            width: 16px;
            height: 16px;
            fill: currentColor;
            transition: transform 0.3s;
        }

        /* =========================================================
           Hover: Transform & Warp Animation
           ========================================================= */
        .notion-btn:hover {
            /* Transform and Skew for the Warp effect */
            transform: scale(1.08) perspective(200px) rotateX(4deg) rotateY(-4deg) skew(-2deg, 1deg);
            /* Morphing the border radius to warp the shape */
            border-radius: 16px 4px 16px 4px; 
            border-color: var(--notion-text);
            box-shadow: -4px 8px 15px rgba(0, 0, 0, 0.1);
            background-color: #f7f7f5; /* Very subtle Notion hover background */
        }

        .notion-btn:hover .btn-text svg {
            transform: scale(1.2);
        }

        /* Active/Click State */
        .notion-btn:active {
            transform: scale(0.96) skew(1deg, -1deg);
            border-radius: 4px;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
        }

        /* =========================================================
           Loading State Styles
           ========================================================= */
        .loader-spinner {
            position: absolute;
            width: 18px;
            height: 18px;
            border: 2px solid var(--notion-border);
            border-top-color: var(--notion-text);
            border-radius: 50%;
            opacity: 0;
            animation: spin 0.8s linear infinite;
            transition: opacity 0.3s;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .notion-btn.is-loading {
            pointer-events: none;
            transform: scale(1); /* Reset warp */
            border-radius: 22px; /* Morph into pill shape */
            background-color: var(--notion-bg);
            border-color: var(--notion-border);
            box-shadow: none;
        }

        .notion-btn.is-loading .btn-text {
            opacity: 0;
            transform: scale(0.8);
        }

        .notion-btn.is-loading .loader-spinner {
            opacity: 1;
        }

    </style>
</head>
<body>

    <!-- Fake Chrome Page Loader -->
    <div id="page-loader"></div>

    <!-- Centered Widget Button -->
    <button class="notion-btn" id="redirect-btn">
        <span class="btn-text">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
            </svg>
            YouTube
        </span>
        <span class="loader-spinner"></span>
    </button>

    <script>
        const btn = document.getElementById('redirect-btn');
        const pageLoader = document.getElementById('page-loader');

        btn.addEventListener('click', () => {
            // 1. Trigger the button's internal loading morph animation
            btn.classList.add('is-loading');

            // 2. Trigger the top page progress bar (Chrome style)
            pageLoader.style.width = '75%';

            // 3. Simulate network latency/loading time, then execute redirect
            setTimeout(() => {
                // Finish the progress bar
                pageLoader.style.width = '100%';
                
                // Slight delay to allow the user to see the bar complete before redirect
                setTimeout(() => {
                    // Redirect to YouTube on the same tab
                    window.location.href = 'https://www.youtube.com';
                }, 300);
                
            }, 1200); // 1.2 seconds simulated load time
        });
    </script>
</body>
</html>
