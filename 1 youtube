                <div class="bar" style="height: 70%;"></div>
                <div class="bar" style="height: 100%;"></div>
                <div class="bar" style="height: 60%;"></div>
            </div>
            <div>
                <p style="font-size: 0.75rem; color: var(--text-muted);">Total earning</p>
                <div style="font-weight: 600;">$12,875 <span class="trend up" style="font-size: 0.7rem; font-weight: 400;">▲ 10%</span></div>
            </div>
        </div>
    </div>

    <!-- CENTER COLUMN -->
    <div class="col-center">
        <div class="filters">
            <div class="filter-btn" onclick="randomizeData(this)">1W</div>
            <div class="filter-btn" onclick="randomizeData(this)">1M</div>
            <div class="filter-btn active" onclick="randomizeData(this)">3M</div>
            <div class="filter-btn" onclick="randomizeData(this)">1Y</div>
            <div class="filter-btn" onclick="randomizeData(this)">ALL</div>
        </div>

        <div class="radar-container" id="radarContainer">
            <svg class="radar-chart" id="radarSvg" viewBox="0 0 500 500">
                <g id="radarGrid"></g>
                <g id="radarAxes"></g>
                <!-- Paths -->
                <path id="pathBlue" class="radar-path blue" d=""></path>
                <path id="pathPink" class="radar-path pink" d=""></path>
                <!-- Draggable Nodes Group -->
                <g id="radarNodes"></g>
            </svg>
            <div class="radar-labels" id="radarLabels">
                <!-- Labels injected via JS -->
            </div>
        </div>
    </div>

    <!-- RIGHT COLUMN -->
    <div class="col-right">
        <div class="header-stats">
            <p>last month<br>All figures are normal</p>
            <h2>$12,875 <span class="trend up" style="font-size: 1rem; font-weight:400;">▲ 10%</span></h2>
            <p style="font-size: 0.7rem; margin-top:5px;">Compared to $21,490 last year</p>
        </div>

        <!-- Transformative Database Card (Clickable Redirect) -->
        <div class="db-card" id="dbCard" title="Click to open YouTube">
            
            <div class="donut-container">
                <svg class="donut" viewBox="0 0 100 100">
                    <circle class="donut-bg" cx="50" cy="50" r="40"></circle>
                    <circle class="donut-segment donut-pink" id="dSeg1" cx="50" cy="50" r="40" stroke-dasharray="100 151.3" stroke-dashoffset="0"></circle>
                    <circle class="donut-segment donut-orange" id="dSeg2" cx="50" cy="50" r="30" stroke-dasharray="80 108.5" stroke-dashoffset="0"></circle>
                    <circle class="donut-segment donut-blue" id="dSeg3" cx="50" cy="50" r="20" stroke-dasharray="60 65.6" stroke-dashoffset="0"></circle>
                </svg>
                <div class="donut-center" id="donutIcon">
                    <!-- Checkmark Icon -->
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-purple)" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
            </div>

            <div class="db-card-title">
                <h3>Total earning</h3>
