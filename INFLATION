    <!-- Minimalist Custom Chrome-Style Transition Screen overlay -->
    <div id="loaderOverlay" class="fixed inset-0 bg-notion-lightBg dark:bg-notion-darkBg z-50 flex flex-col items-center justify-center pointer-events-none opacity-0 scale-105 transition-all duration-700 ease-out">
        <div class="w-full max-w-xl px-6 flex flex-col items-center">
            
            <!-- Mock Chrome Browser Window Header bar -->
            <div class="w-full bg-neutral-100 dark:bg-neutral-900/80 border border-neutral-200 dark:border-neutral-800 rounded-t-xl p-3.5 flex items-center space-x-2 shadow-sm">
                <!-- Mac style browser control buttons -->
                <div class="flex space-x-1.5 flex-shrink-0">
                    <span class="w-3 h-3 rounded-full bg-red-400/80 block"></span>
                    <span class="w-3 h-3 rounded-full bg-yellow-400/80 block"></span>
