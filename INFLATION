                    </span>

                    <!-- Decorative Border bottom glow -->
                    <div class="absolute inset-x-0 bottom-0 h-[2px] bg-gradient-to-r from-transparent via-neutral-500 to-transparent opacity-0 group-hover/btn:opacity-100 transition-opacity duration-300"></div>
                </button>
            </div>
        </div>
