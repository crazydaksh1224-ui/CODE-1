<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cookie Inflation Widget</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #111113;
            --card-dark: #1A1A1E;
            --lime: #D4FF00;
            --purple: #9E77F6;
            --pink: #FF79DA;
            --text-light: #FFFFFF;
            --text-muted: #A1A1AA;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
            background-color: transparent;
            color: var(--text-light);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            overflow-x: hidden;
        }

        .widget-container {
            width: 100%;
            max-width: 480px;
            background: var(--bg-dark);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            border: 2px solid #27272A;
        }

        .header {
            text-align: center;
            margin-bottom: 24px;
        }

        .header h1 {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 8px;
        }

        .header h1 span {
            color: var(--lime);
        }

        .header p {
            color: var(--text-muted);
            font-size: 13px;
            line-height: 1.5;
        }

        /* 3D Transform/Warp Card Container */
        .card-perspective {
            perspective: 1000px;
            margin-bottom: 20px;
        }

        .interactive-card {
            background: var(--card-dark);
            border-radius: 20px;
            padding: 20px;
            border: 1px solid #27272A;
            transform-style: preserve-3d;
            transition: transform 0.1s ease, box-shadow 0.2s ease;
            will-change: transform;
        }

        .interactive-card:hover {
            box-shadow: 0 15px 30px rgba(158, 119, 246, 0.15);
        }

        .card-title {
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
            display: inline-block;
            padding: 4px 8px;
            border-radius: 6px;
        }

        .title-purple { background: rgba(158, 119, 246, 0.15); color: var(--purple); }
        .title-pink { background: rgba(255, 121, 218, 0.15); color: var(--pink); }

        /* Control & Sliders */
        .control-group {
            margin-bottom: 16px;
        }

        .control-label {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .control-label .val {
            font-weight: 800;
            color: var(--lime);
        }

        input[type=range] {
            -webkit-appearance: none;
            width: 100%;
            background: #27272A;
            height: 8px;
            border-radius: 4px;
            outline: none;
        }

        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--lime);
            cursor: pointer;
            transition: transform 0.1s ease;
        }

        input[type=range]::-webkit-slider-thumb:hover {
            transform: scale(1.2);
        }

        /* Formula Card Styling */
        .formula-display {
            background: #09090B;
            border-radius: 12px;
            padding: 16px;
            font-family: monospace;
            font-size: 13px;
            line-height: 1.6;
            border: 1px dashed #3F3F46;
            margin-bottom: 16px;
            overflow-x: auto;
        }

        .formula-line {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
            gap: 4px;
        }

        .fraction {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            vertical-align: middle;
            padding: 0 4px;
        }

        .numerator {
            border-bottom: 1px solid var(--text-light);
            padding-bottom: 2px;
            width: 100%;
            text-align: center;
        }

        .denominator {
            padding-top: 2px;
            width: 100%;
            text-align: center;
        }

        .highlight-new { color: var(--pink); font-weight: bold; }
        .highlight-old { color: var(--purple); font-weight: bold; }

        /* Real-Time Result Badge */
        .result-box {
            background: var(--lime);
            color: var(--bg-dark);
            border-radius: 16px;
            padding: 16px;
            text-align: center;
            font-weight: 800;
            transform-style: preserve-3d;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .result-box h2 {
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            opacity: 0.8;
        }

        .result-value {
            font-size: 32px;
            font-weight: 800;
            margin-top: 4px;
        }

        /* Interactive Cookie Visualizer */
        .cookie-container {
            display: flex;
            justify-content: space-around;
            margin-top: 12px;
            background: #09090B;
            padding: 12px;
            border-radius: 12px;
        }

        .cookie-basket {
            text-align: center;
            font-size: 11px;
            color: var(--text-muted);
        }

        .basket-graphic {
            font-size: 28px;
            margin-bottom: 4px;
            transition: transform 0.3s ease;
        }
    </style>
</head>
<body>

    <div class="widget-container">
        <div class="header">
            <h1>Cookie <span>Inflation</span> Tracker</h1>
            <p>Tracking the cost of a standard assorted basket of cookies over time to calculate real-time inflation.</p>
        </div>

        <div class="card-perspective">
            <div class="interactive-card" id="inputCard">
                <span class="card-title title-purple">1. Market Basket Pricing</span>
                
                <div class="control-group">
                    <div class="control-label">
                        <span>Old Cookie Basket Cost (CPI Old)</span>
                        <span class="val" style="color: var(--purple);">$<span id="lblOld">100</span></span>
                    </div>
                    <input type="range" id="cpiOld" min="50" max="200" value="100">
                </div>

                <div class="control-group">
                    <div class="control-label">
                        <span>New Cookie Basket Cost (CPI New)</span>
                        <span class="val" style="color: var(--pink);">$<span id="lblNew">125</span></span>
                    </div>
                    <input type="range" id="cpiNew" min="50" max="250" value="125">
                </div>

                <div class="cookie-container">
                    <div class="cookie-basket" id="basketOld">
                        <div class="basket-graphic">🍪</div>
                        <div>Past Basket</div>
                    </div>
                    <div class="cookie-basket" id="basketNew">
                        <div class="basket-graphic">🍪</div>
                        <div>Present Basket</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-perspective">
            <div class="interactive-card" id="formulaCard">
                <span class="card-title title-pink">2. The Inflation Formula</span>
                
                <div class="formula-display">
                    <div class="formula-line">
                        <span>Inflation Rate =</span>
                        <div class="fraction">
                            <span class="numerator"><span class="highlight-new" id="fNew">125</span> - <span class="highlight-old" id="fOld1">100</span></span>
                            <span class="denominator"><span class="highlight-old" id="fOld2">100</span></span>
                        </div>
                        <span>× 100</span>
                    </div>
                </div>

                <div class="result-box" id="resultBox">
                    <h2>Live Inflation Rate</h2>
                    <div class="result-value"><span id="rateResult">25.0</span>%</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const cpiOldInput = document.getElementById('cpiOld');
        const cpiNewInput = document.getElementById('cpiNew');
        const lblOld = document.getElementById('lblOld');
        const lblNew = document.getElementById('lblNew');
        
        const fOld1 = document.getElementById('fOld1');
        const fOld2 = document.getElementById('fOld2');
        const fNew = document.getElementById('fNew');
        const rateResult = document.getElementById('rateResult');
        
        const basketOld = document.querySelector('#basketOld .basket-graphic');
        const basketNew = document.querySelector('#basketNew .basket-graphic');
        const resultBox = document.getElementById('resultBox');

        function updateCalculations() {
            const oldVal = parseFloat(cpiOldInput.value);
            const newVal = parseFloat(cpiNewInput.value);

            // Update text metrics
            lblOld.innerText = oldVal;
            lblNew.innerText = newVal;
            fOld1.innerText = oldVal;
            fOld2.innerText = oldVal;
            fNew.innerText = newVal;

            // Calculate Inflation Rate
            const inflationRate = ((newVal - oldVal) / oldVal) * 100;
            rateResult.innerText = inflationRate.toFixed(1);

            // Dynamic size transformation based on relative value shifts
            basketOld.style.transform = `scale(${0.7 + (oldVal / 200)})`;
            basketNew.style.transform = `scale(${0.7 + (newVal / 200)})`;

            // Transform color intensity of the result badge if negative inflation (deflation)
            if (inflationRate < 0) {
                resultBox.style.background = '#FF79DA';
            } else if (inflationRate === 0) {
                resultBox.style.background = '#FFFFFF';
            } else {
                resultBox.style.background = '#D4FF00';
            }
        }

        // 3D Warp / Perspective Tilt Effect
        function applyWarpEffect(cardId) {
            const card = document.getElementById(cardId);
            card.parentElement.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const xc = rect.width / 2;
                const yc = rect.height / 2;
                
                const angleX = (yc - y) / 10;
                const angleY = (x - xc) / 10;
                
                card.style.transform = `rotateX(${angleX}deg) rotateY(${angleY}deg) scale(1.02)`;
            });

            card.parentElement.addEventListener('mouseleave', () => {
                card.style.transform = 'rotateX(0deg) rotateY(0deg) scale(1)';
            });
        }

        // Initialize listeners
        cpiOldInput.addEventListener('input', updateCalculations);
        cpiNewInput.addEventListener('input', updateCalculations);

        applyWarpEffect('inputCard');
        applyWarpEffect('formulaCard');

        // Initial Run
        updateCalculations();
    </script>
</body>
</html>
