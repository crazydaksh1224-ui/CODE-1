                    <input type="range" id="idleSpeedSlider" min="0.1" max="2.0" step="0.1" value="0.4" class="w-full accent-neutral-800 dark:accent-neutral-200 bg-neutral-200 dark:bg-neutral-800 h-1 rounded-lg appearance-none cursor-pointer">
