<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Macroeconomic Inflation Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #111113;
            --card-dark: #1A1A1E;
            --lime: #D4FF00;
            --purple: #9E77F6;
            --pink: #FF79DA;
            --text-light: #FFFFFF;
            --text-muted: #A1A1AA;
            
            --hyperinflation: #FF2E93;
            --galloping: #FF79DA;
            --creeping: #D4FF00;
            --stability: #FFFFFF;
            --deflation: #9E77F6;
            --spiral: #20E9FF;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        /* Removed flex-centering on body to prevent iframe collapse */
        body {
            background-color: #111113;
            color: var(--text-light);
            padding: 20px;
            display: block; 
        }

        /* Fixed, rigid width and automatic block display for Notion stability */
        .widget-container {
            width: 100%;
            max-width: 900px;
            margin: 0 auto;
            background: var(--bg-dark);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.6);
            border: 2px solid #27272A;
        }

        .header {
            text-align: left;
            margin-bottom: 24px;
            border-bottom: 1px solid #27272A;
            padding-bottom: 16px;
        }

        .header h1 {
            font-size: 26px;
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 6px;
        }

        .header h1 span {
            color: var(--lime);
        }

        .header p {
            color: var(--text-muted);
            font-size: 13px;
            line-height: 1.5;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 1.1fr 1fr;
            gap: 20px;
        }

        @media (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
        }

        .card-perspective {
            perspective: 1200px;
        }

        .interactive-card {
            background: var(--card-dark);
            border-radius: 20px;
            padding: 24px;
            border: 1px solid #27272A;
            transform-style: preserve-3d;
            transition: transform 0.1s ease, box-shadow 0.2s ease;
            will-change: transform;
        }

        .card-title {
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 20px;
            display: inline-block;
            padding: 6px 12px;
            border-radius: 8px;
        }

        .title-purple { background: rgba(158, 119, 246, 0.15); color: var(--purple); }
        .title-pink { background: rgba(255, 121, 218, 0.15); color: var(--pink); }

        /* Massive, uncollapsible box window */
        .giant-cookie-showcase {
            background: #09090B;
            border-radius: 16px;
            padding: 60px 20px; 
            display: flex;
            justify-content: space-around;
            align-items: center;
            gap: 20px;
            border: 1px solid #1E1E21;
            min-height: 280px; 
        }

        .cookie-vault-box {
            text-align: center;
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .cookie-vault-box span {
            font-size: 11px;
            font-weight: 800;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 24px;
            line-height: 1.4;
        }

        /* Massive base size scaling asset */
        .giant-cookie-graphic {
            font-size: 80px; 
            filter: drop-shadow(0 15px 25px rgba(0,0,0,0.6));
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: inline-block;
        }

        .right-column {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .control-group {
            margin-bottom: 16px;
        }

        .control-group:last-child {
            margin-bottom: 0;
        }

        .control-label {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        input[type=range] {
            -webkit-appearance: none;
            width: 100%;
            background: #27272A;
            height: 8px;
            border-radius: 4px;
            outline: none;
        }

        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--lime);
            cursor: pointer;
            border: 2px solid var(--bg-dark);
        }

        .formula-display {
            background: #09090B;
            border-radius: 12px;
            padding: 16px;
            font-family: monospace;
            font-size: 13px;
            border: 1px dashed #3F3F46;
        }

        .formula-line {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .fraction {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            vertical-align: middle;
            padding: 0 6px;
        }

        .numerator {
            border-bottom: 2px solid var(--text-light);
            padding-bottom: 2px;
            width: 100%;
            text-align: center;
        }

        .denominator {
            padding-top: 2px;
            width: 100%;
            text-align: center;
        }

        .highlight-new { color: var(--pink); font-weight: bold; }
        .highlight-old { color: var(--purple); font-weight: bold; }

        .global-result-box {
            background: #27272A;
            border-radius: 14px;
            padding: 14px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid #3F3F46;
        }

        .global-result-box h2 {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .global-result-value {
            font-size: 32px;
            font-weight: 800;
            color: var(--lime);
        }

        .economic-state-banner {
            border-radius: 16px;
            padding: 18px;
            color: var(--bg-dark);
            transition: all 0.3s ease;
        }

        .state-tag {
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            background: rgba(0,0,0,0.12);
            padding: 4px 8px;
            border-radius: 4px;
            display: inline-block;
            margin-bottom: 6px;
        }

        .state-title {
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 4px;
        }

        .state-description {
            font-size: 12px;
            font-weight: 500;
            opacity: 0.9;
            line-height: 1.4;
        }
    </style>
</head>
<body>

    <div class="widget-container">
        <div class="header">
            <h1>Macroeconomic <span>Inflation</span> Dashboard</h1>
            <p>Adjust market variables to scale asset structures and determine systemic conditions.</p>
        </div>

        <div class="dashboard-grid">
            
            <div class="card-perspective">
                <div class="interactive-card" id="cookieCard">
                    <span class="card-title title-purple">Visual Asset Multiplier</span>
                    
                    <div class="giant-cookie-showcase">
                        <div class="cookie-vault-box">
                            <div class="giant-cookie-graphic" id="cookieOld">🍪</div>
                            <span>Past Base Basket<br>($<span id="labelOldSub">100</span>)</span>
                        </div>
                        <div class="cookie-vault-box">
                            <div class="giant-cookie-graphic" id="cookieNew">🍪</div>
                            <span>Present Scale Basket<br>($<span id="labelNewSub">105</span>)</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="right-column">
                
                <div class="card-perspective">
                    <div class="interactive-card" id="controlCard">
                        <span class="card-title title-pink">Market Metrics</span>
                        
                        <div class="control-group">
                            <div class="control-label">
                                <span>CPI Target Base (Old Cost)</span>
                                <span class="val" style="color: var(--purple);">$<span id="lblOld">100</span></span>
                            </div>
                            <input type="range" id="cpiOld" min="50" max="200" value="100">
                        </div>

                        <div class="control-group">
                            <div class="control-label">
                                <span>CPI Terminal Index (New Cost)</span>
                                <span class="val" style="color: var(--pink);">$<span id="lblNew">105</span></span>
                            </div>
                            <input type="range" id="cpiNew" min="20" max="300" value="105">
                        </div>
                    </div>
                </div>

                <div class="formula-display">
                    <div class="formula-line">
                        <span>Inflation Rate =</span>
                        <div class="fraction">
                            <span class="numerator"><span class="highlight-new" id="fNew">105</span> - <span class="highlight-old" id="fOld1">100</span></span>
                            <span class="denominator"><span class="highlight-old" id="fOld2">100</span></span>
                        </div>
                        <span>× 100</span>
                    </div>
                </div>

                <div class="global-result-box">
                    <h2>Calculated Rate Output</h2>
                    <div class="global-result-value"><span id="rateResult">5.0</span>%</div>
                </div>

                <div class="economic-state-banner" id="stateBanner">
                    <span class="state-tag">Economic Condition Matrix</span>
                    <div class="state-title" id="stateTitle">Creeping Inflation</div>
                    <div class="state-description" id="stateDesc">Healthy baseline growth pattern. Standard consumer operations active.</div>
                </div>

            </div>
        </div>
    </div>

    <script>
        const cpiOldInput = document.getElementById('cpiOld');
        const cpiNewInput = document.getElementById('cpiNew');
        const lblOld = document.getElementById('lblOld');
        const lblNew = document.getElementById('lblNew');
        const labelOldSub = document.getElementById('labelOldSub');
        const labelNewSub = document.getElementById('labelNewSub');
        
        const fOld1 = document.getElementById('fOld1');
        const fOld2 = document.getElementById('fOld2');
        const fNew = document.getElementById('fNew');
        const rateResult = document.getElementById('rateResult');
        
        const cookieOld = document.getElementById('cookieOld');
        const cookieNew = document.getElementById('cookieNew');
        
        const stateBanner = document.getElementById('stateBanner');
        const stateTitle = document.getElementById('stateTitle');
        const stateDesc = document.getElementById('stateDesc');

        function updateCalculations() {
            const oldVal = parseFloat(cpiOldInput.value);
            const newVal = parseFloat(cpiNewInput.value);

            lblOld.innerText = oldVal;
            lblNew.innerText = newVal;
            labelOldSub.innerText = oldVal;
            labelNewSub.innerText = newVal;
            fOld1.innerText = oldVal;
            fOld2.innerText = oldVal;
            fNew.innerText = newVal;

            const inflationRate = ((newVal - oldVal) / oldVal) * 100;
            rateResult.innerText = inflationRate.toFixed(1);

            // Massive Visual Asset Multiplier Math
            const ratioOld = (oldVal / 100);
            const ratioNew = (newVal / 100);
            
            cookieOld.style.transform = `scale(${Math.max(0.4, Math.min(ratioOld * 1.5, 2.6))})`;
            cookieNew.style.transform = `scale(${Math.max(0.4, Math.min(ratioNew * 1.5, 2.6))})`;

            // 6 Distinct Structural Economy States Matrix
            let stateName = "";
            let stateInfo = "";
            let stateColor = "";

            if (inflationRate >= 50) {
                stateName = "🚨 Hyperinflation";
                stateInfo = "Currency is devaluing destructively. Cash balances rapidly become worthless as price vectors scale exponentially out of control.";
                stateColor = "var(--hyperinflation)";
            } else if (inflationRate >= 10 && inflationRate < 50) {
                stateName = "🏃💨 Galloping Inflation";
                stateInfo = "High, aggressive structural price climbs. Capital flight begins, and central banks are forced into rapid, emergency interest rate hikes.";
                stateColor = "var(--pink)";
            } else if (inflationRate > 0 && inflationRate < 10) {
                stateName = "🌱 Creeping Inflation";
                stateInfo = "Mild, predictable expansion. Optimal systemic condition indicating healthy product demand and sustained labor productivity gains.";
                stateColor = "var(--creeping)";
            } else if (inflationRate === 0) {
                stateName = "⚖️ Price Stability";
                stateInfo = "Perfect structural equilibrium. Net zero shifting in average market indexes. Capital velocities remain constant.";
                stateColor = "var(--stability)";
            } else if (inflationRate < 0 && inflationRate >= -10) {
                stateName = "❄️ Deflationary Realignment";
                stateInfo = "Falling aggregate consumer price metrics. Encourages hoarding of cash reserves, dampening systemic investments and delaying commercial spend.";
                stateColor = "var(--deflation)";
            } else if (inflationRate < -10) {
                stateName = "💥 Debt-Deflation Spiral";
                stateInfo = "Severe systemic contraction. Collapsing product margins drive structural bankruptcies and mass insolvency as real debt burdens surge violently upward.";
                stateColor = "var(--spiral)";
            }

            stateTitle.innerText = stateName;
            stateDesc.innerText = stateInfo;
            stateBanner.style.backgroundColor = stateColor;
        }

        function applyWarpEffect(cardId) {
            const card = document.getElementById(cardId);
            card.parentElement.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                const xc = rect.width / 2;
                const yc = rect.height / 2;
                const angleX = (yc - y) / 14;
                const angleY = (x - xc) / 14;
                
                card.style.transform = `rotateX(${angleX}deg) rotateY(${angleY}deg) scale(1.01)`;
            });

            card.parentElement.addEventListener('mouseleave', () => {
                card.style.transform = 'rotateX(0deg) rotateY(0deg) scale(1)';
            });
        }

        cpiOldInput.addEventListener('input', updateCalculations);
        cpiNewInput.addEventListener('input', updateCalculations);

        applyWarpEffect('cookieCard');
        applyWarpEffect('controlCard');
        
        updateCalculations();
    </script>
</body>
</html>
