        </div>

        <div class="border-t border-notion-lightBorder dark:border-notion-darkBorder pt-4">
            <p class="text-[10px] text-neutral-400 font-mono leading-relaxed">
                Interact with the central monolith. Hovering triggers acceleration. Clicking simulates a secure transfer protocols directly towards YouTube.
            </p>
        </div>
    </aside>

    <!-- Center Button Widget Master Container -->
    <main class="relative z-10 w-full max-w-lg px-6 flex flex-col items-center justify-center">
        <!-- Parallax/Tilt 3D Space Wrapper -->
        <div id="tiltWrapper" class="perspective-container w-full flex flex-col items-center justify-center py-10">
            
            <!-- Beautiful High-Contrast Central Monolith Box -->
            <div id="widgetCard" class="tilt-card w-full max-w-sm p-10 bg-notion-lightBg dark:bg-notion-darkBg border border-notion-lightBorder dark:border-notion-darkBorder rounded-2xl shadow-[0_12px_40px_rgba(0,0,0,0.03)] dark:shadow-[0_20px_50px_rgba(0,0,0,0.3)] flex flex-col items-center justify-center text-center relative group overflow-hidden">
                
                <!-- Gloss Reflection Overlay layer -->
                <div id="cardShine" class="card-shine"></div>

