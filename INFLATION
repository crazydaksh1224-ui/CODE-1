        <div>
            <div class="flex justify-between items-center mb-6 border-b border-notion-lightBorder dark:border-notion-darkBorder pb-4">
                <h3 class="font-semibold text-xs tracking-wider text-neutral-600 dark:text-neutral-400 uppercase">Interactive Variables</h3>
                <button id="closeSettings" class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200">
                    <i class="fa-solid fa-times"></i>
