                    <p id="loaderStatus" class="text-[11px] text-neutral-400 font-mono tracking-tight bg-neutral-50 dark:bg-neutral-900/60 py-2 px-3 rounded-lg border border-neutral-150 dark:border-neutral-800/80 min-h-[36px] flex items-center justify-center">Extracting host metadata...</p>
                </div>

                <!-- Elegant Linear progress completion meter -->
                <div class="w-full max-w-xs bg-neutral-100 dark:bg-neutral-900 h-1.5 rounded-full overflow-hidden shadow-inner">
                    <div id="progressBar" class="w-0 bg-neutral-800 dark:bg-neutral-100 h-full transition-all duration-300 ease-out"></div>
