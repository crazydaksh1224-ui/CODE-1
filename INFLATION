    <!-- Footer subtle credits layout -->
    <footer class="absolute bottom-5 left-0 w-full text-center z-20">
        <p class="text-[9px] text-neutral-400/80 font-mono tracking-widest uppercase">Monolithic Core System Interface</p>
    </footer>

    <script>
        // Guardrail helper for sandboxed environments like iframe previews
        function getSafeStorage(key, defaultVal) {
            try {
                const item = localStorage.getItem(key);
                return item !== null ? item : defaultVal;
            } catch (e) {
                return defaultVal;
            }
        }

        function setSafeStorage(key, val) {
            try {
                localStorage.setItem(key, val);
            } catch (e) {}
        }

        const themeToggle = document.getElementById('themeToggle');
        const soundToggle = document.getElementById('soundToggle');
        const soundIcon = document.getElementById('soundIcon');
        const settingsToggle = document.getElementById('settingsToggle');
        const settingsPanel = document.getElementById('settingsPanel');
        const closeSettings = document.getElementById('closeSettings');
        const widgetCard = document.getElementById('widgetCard');
        const tiltWrapper = document.getElementById('tiltWrapper');
        const cardShine = document.getElementById('cardShine');
        const warpButton = document.getElementById('warpButton');
        const btnLabel = document.getElementById('btnLabel');
        const btnLabelInput = document.getElementById('btnLabelInput');
        const particleSlider = document.getElementById('particleSlider');
        const particleVal = document.getElementById('particleVal');
        const idleSpeedSlider = document.getElementById('idleSpeedSlider');
        const idleSpeedVal = document.getElementById('idleSpeedVal');
        const hoverSpeedSlider = document.getElementById('hoverSpeedSlider');
        const hoverSpeedVal = document.getElementById('hoverSpeedVal');
        const patternSelect = document.getElementById('patternSelect');
        const loaderOverlay = document.getElementById('loaderOverlay');
        const loaderStatus = document.getElementById('loaderStatus');
        const progressBar = document.getElementById('progressBar');
        const tabUrlText = document.getElementById('tabUrlText');
        const warpCanvas = document.getElementById('warpCanvas');
        const monolithIcon = document.getElementById('monolithIcon');
        const ctx = warpCanvas.getContext('2d');

        let state = {
            theme: getSafeStorage('theme', 'light'),
            soundEnabled: getSafeStorage('soundEnabled', 'true') === 'true',
            particleCount: parseInt(particleSlider.value),
            idleWarpSpeed: parseFloat(idleSpeedSlider.value),
            hoverWarpSpeed: parseFloat(hoverSpeedSlider.value),
            isHovered: false,
            currentSpeed: parseFloat(idleSpeedSlider.value),
            buttonLabel: btnLabelInput.value,
            warpPattern: patternSelect.value,
            isRedirecting: false
        };

        let particles = [];
        let cx = window.innerWidth / 2;
        let cy = window.innerHeight / 2;

        function resizeCanvas() {
            warpCanvas.width = window.innerWidth;
            warpCanvas.height = window.innerHeight;
            cx = warpCanvas.width / 2;
            cy = warpCanvas.height / 2;
        }
        window.addEventListener('resize', () => {
            resizeCanvas();
            initParticles();
        });
        resizeCanvas();

        // Premium Monotonic Synth sound triggers
        function playSynthPitch(frequency, duration, type = 'sine', fadeOut = true) {
            if (!state.soundEnabled) return;
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                
                osc.type = type;
                osc.frequency.setValueAtTime(frequency, audioCtx.currentTime);
                
                gain.gain.setValueAtTime(0.08, audioCtx.currentTime);
                if (fadeOut) {
                    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration);
                }
                
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                
                osc.start();
                osc.stop(audioCtx.currentTime + duration);
            } catch (err) {
                console.log("Audio Engine context bypassed in iframe scenario.");
            }
        }

        class WarpParticle {
            constructor() {
                this.reset();
            }

            reset() {
                // Positional distribution in perspective space coordinates
                this.x = (Math.random() - 0.5) * warpCanvas.width * 2;
                this.y = (Math.random() - 0.5) * warpCanvas.height * 2;
                this.z = Math.random() * warpCanvas.width;
                
                // Track previous coordinates for projection stretch traces
                this.px = this.x;
                this.py = this.y;
                
                // Custom orbit and spiral attributes
                this.angle = Math.random() * Math.PI * 2;
                this.radius = Math.sqrt(this.x * this.x + this.y * this.y);
                this.angularVelocity = (Math.random() - 0.5) * 0.02;
            }

            update(speed) {
                this.px = this.x;
                this.py = this.y;
                
                if (state.warpPattern === 'classic') {
                    // Pull closer straight along Z vector
                    this.z -= speed;
                    if (this.z <= 0) {
                        this.reset();
                        this.z = warpCanvas.width;
                    }
                } else if (state.warpPattern === 'vortex') {
                    // Swirl towards viewer along dynamic angle helix path
                    this.angle += this.angularVelocity * (speed * 0.5 + 0.5);
                    this.z -= speed;
                    this.x = Math.cos(this.angle) * this.radius;
                    this.y = Math.sin(this.angle) * this.radius;
                    if (this.z <= 0) {
                        this.reset();
                        this.z = warpCanvas.width;
                    }
                } else if (state.warpPattern === 'radial') {
                    // Expands directly outwards along radial vector offsets
                    this.z -= speed * 0.5;
                    const expansionFactor = 1 + (speed * 0.01);
                    this.x *= expansionFactor;
                    this.y *= expansionFactor;
                    if (Math.abs(this.x) > warpCanvas.width || Math.abs(this.y) > warpCanvas.height) {
                        this.reset();
                    }
                } else if (state.warpPattern === 'helix') {
                    // Continuous spiral orbits
                    this.angle += 0.01 * (speed * 0.2 + 0.5);
                    this.z -= speed;
                    this.x = Math.cos(this.angle) * (this.radius + (warpCanvas.width - this.z) * 0.2);
                    this.y = Math.sin(this.angle) * (this.radius + (warpCanvas.width - this.z) * 0.2);
                    if (this.z <= 0) {
                        this.reset();
                        this.z = warpCanvas.width;
                    }
                }
            }

            draw() {
                // Standard projection variables onto flattened screen coords
                let sx, sy, psx, psy;
                
                if (state.warpPattern === 'radial') {
                    sx = this.x + cx;
                    sy = this.y + cy;
                    psx = this.px + cx;
                    psy = this.py + cy;
                } else {
                    sx = (this.x / this.z) * cx + cx;
                    sy = (this.y / this.z) * cy + cy;
                    psx = (this.px / (this.z + state.currentSpeed)) * cx + cx;
                    psy = (this.py / (this.z + state.currentSpeed)) * cy + cy;
                }

                // Render condition limits
                if (sx < 0 || sx > warpCanvas.width || sy < 0 || sy > warpCanvas.height) {
                    return;
                }

                // Smoothly fade alpha based on Z proximity
                const alpha = Math.min(1.0, 1 - this.z / warpCanvas.width);
                const strokeColor = state.theme === 'dark' 
                    ? `rgba(235, 235, 235, ${alpha})`
                    : `rgba(55, 53, 47, ${alpha})`;

                ctx.strokeStyle = strokeColor;
                ctx.lineWidth = Math.max(0.8, (1 - this.z / warpCanvas.width) * 3);
                ctx.beginPath();
                ctx.moveTo(psx, psy);
                ctx.lineTo(sx, sy);
                ctx.stroke();
            }
        }

        function initParticles() {
            particles = [];
            for (let i = 0; i < state.particleCount; i++) {
                particles.push(new WarpParticle());
            }
        }
        initParticles();

        function drawFrame() {
            // Semi-transparent overlay to draw fluid tails/smear effect over existing frames
            ctx.fillStyle = state.theme === 'dark' 
                ? 'rgba(25, 25, 25, 0.28)' 
                : 'rgba(251, 251, 250, 0.28)';
            ctx.fillRect(0, 0, warpCanvas.width, warpCanvas.height);

            // Smooth linear speed interpolation towards target thresholds
            const targetSpeed = state.isHovered ? state.hoverWarpSpeed : state.idleWarpSpeed;
            state.currentSpeed += (targetSpeed - state.currentSpeed) * 0.1;

            particles.forEach(p => {
                p.update(state.currentSpeed);
                p.draw();
            });

            requestAnimationFrame(drawFrame);
        }
        drawFrame();

        function updateTheme() {
            if (state.theme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
            setSafeStorage('theme', state.theme);
        }
        updateTheme();

        function updateSoundIcon() {
            if (state.soundEnabled) {
                soundIcon.className = "fa-solid fa-volume-high text-xs";
                soundToggle.classList.remove('opacity-50');
            } else {
                soundIcon.className = "fa-solid fa-volume-xmark text-xs";
                soundToggle.classList.add('opacity-50');
            }
        }
        updateSoundIcon();

        themeToggle.addEventListener('click', () => {
            state.theme = state.theme === 'light' ? 'dark' : 'light';
            updateTheme();
            playSynthPitch(440, 0.15, 'triangle');
        });

        soundToggle.addEventListener('click', () => {
            state.soundEnabled = !state.soundEnabled;
            setSafeStorage('soundEnabled', state.soundEnabled.toString());
            updateSoundIcon();
            if (state.soundEnabled) {
                playSynthPitch(600, 0.1, 'sine');
            }
        });

        settingsToggle.addEventListener('click', () => {
            settingsPanel.classList.remove('translate-x-full');
            playSynthPitch(520, 0.1, 'sine');
        });

        closeSettings.addEventListener('click', () => {
            settingsPanel.classList.add('translate-x-full');
            playSynthPitch(380, 0.1, 'sine');
        });

        // Config Sliders Input Actions
        particleSlider.addEventListener('input', (e) => {
            const count = parseInt(e.target.value);
            particleVal.textContent = count;
            state.particleCount = count;
            initParticles();
        });

        idleSpeedSlider.addEventListener('input', (e) => {
            const speed = parseFloat(e.target.value);
            idleSpeedVal.textContent = speed;
            state.idleWarpSpeed = speed;
        });

        hoverSpeedSlider.addEventListener('input', (e) => {
            const speed = parseFloat(e.target.value);
            hoverSpeedVal.textContent = speed;
            state.hoverWarpSpeed = speed;
        });

        patternSelect.addEventListener('change', (e) => {
            state.warpPattern = e.target.value;
            initParticles();
            playSynthPitch(580, 0.12, 'sawtooth');
        });

        btnLabelInput.addEventListener('input', (e) => {
            const val = e.target.value;
            state.buttonLabel = val;
            btnLabel.textContent = val;
        });

        const handleTilt = (e) => {
            const rect = widgetCard.getBoundingClientRect();
            // Compute coordinate cursor offsets normalized from card center
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;

            // Rotation angle variables
            const degX = -(y / (rect.height / 2)) * 14; 
            const degY = (x / (rect.width / 2)) * 14;

            widgetCard.style.transform = `rotateX(${degX}deg) rotateY(${degY}deg) translateY(-6px)`;
            
            // Render beautiful shifting specular highlight based on cursor angle
            cardShine.style.opacity = '1';
            cardShine.style.background = `radial-gradient(circle at ${(e.clientX - rect.left) / rect.width * 100}% ${(e.clientY - rect.top) / rect.height * 100}%, rgba(255,255,255,0.18) 0%, transparent 60%)`;
        };

        const resetTilt = () => {
            widgetCard.style.transform = 'rotateX(0deg) rotateY(0deg) translateY(0px)';
            cardShine.style.opacity = '0';
        };

        tiltWrapper.addEventListener('mousemove', handleTilt);
        tiltWrapper.addEventListener('mouseleave', resetTilt);

        warpButton.addEventListener('mouseenter', () => {
            state.isHovered = true;
            warpButton.style.transform = 'scale(1.04)';
            monolithIcon.classList.add('rotate-45');
            playSynthPitch(280, 0.2, 'sine', true);
            playSynthPitch(380, 0.25, 'triangle', true);
        });

        warpButton.addEventListener('mouseleave', () => {
            state.isHovered = false;
            warpButton.style.transform = 'scale(1)';
            monolithIcon.classList.remove('rotate-45');
        });

        let touchStartX = 0;
        let touchStartY = 0;

        tiltWrapper.addEventListener('touchstart', (e) => {
            const touch = e.touches[0];
            touchStartX = touch.clientX;
            touchStartY = touch.clientY;
            state.isHovered = true;
            playSynthPitch(300, 0.15, 'sine');
        }, { passive: true });

        tiltWrapper.addEventListener('touchend', () => {
            state.isHovered = false;
            resetTilt();
        }, { passive: true });

        tiltWrapper.addEventListener('touchmove', (e) => {
            if (e.touches.length > 0) {
                const touch = e.touches[0];
                const dx = touch.clientX - touchStartX;
                const dy = touch.clientY - touchStartY;
                
                const degX = Math.max(-12, Math.min(12, -(dy / 6)));
                const degY = Math.max(-12, Math.min(12, (dx / 6)));
                
                widgetCard.style.transform = `rotateX(${degX}deg) rotateY(${degY}deg) translateY(-3px)`;
            }
        }, { passive: true });

        warpButton.addEventListener('click', (e) => {
            if (state.isRedirecting) return;
            state.isRedirecting = true;

            // Synthesis click swoosh sweep sound trigger
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(120, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(1200, audioCtx.currentTime + 1.5);
                
                gain.gain.setValueAtTime(0.12, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 1.5);
                
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                
                osc.start();
                osc.stop(audioCtx.currentTime + 1.5);
            } catch (err) {}

            // Dynamic Touch Ripple element instantiation
            const ripple = document.createElement('span');
            ripple.classList.add('ripple');
            
            const rect = warpButton.getBoundingClientRect();
            const x = (e.clientX || (e.touches && e.touches[0].clientX)) - rect.left;
            const y = (e.clientY || (e.touches && e.touches[0].clientY)) - rect.top;
            
            ripple.style.left = `${x}px`;
            ripple.style.top = `${y}px`;
            
            warpButton.appendChild(ripple);
            setTimeout(() => { ripple.remove(); }, 800);

            // Fetch safety parameters of page URL context inside iframe boundaries
            let currentUrl = "https://notion.so/workspace/widget_monolith";
            try {
                if (window.parent && window.parent.location !== window.location) {
                    currentUrl = window.parent.location.href;
                } else {
                    currentUrl = window.location.href;
                }
            } catch (err) {
                currentUrl = window.location.host 
                    ? `${window.location.protocol}//${window.location.host}${window.location.pathname}`
                    : "https://notion.so/workspace/core_widget_space";
            }
            tabUrlText.textContent = currentUrl;

            // Trigger canvas acceleration
            state.hoverWarpSpeed = 48;
            state.isHovered = true;

            // Render Google Chrome Mock overlay layer
            setTimeout(() => {
                loaderOverlay.classList.remove('pointer-events-none');
                loaderOverlay.classList.remove('scale-105', 'opacity-0');
                loaderOverlay.classList.add('opacity-100', 'scale-100');
                
                runLoaderPipeline();
            }, 500);
        });

        const pipeEvents = [
            { txt: "Interpreting current DOM layout structure...", duration: 0, scale: 18, pitch: 480 },
            { txt: "Serializing active host workspace properties...", duration: 700, scale: 35, pitch: 580 },
            { txt: "Validating YouTube connection handshake...", duration: 1500, scale: 62, pitch: 680 },
            { txt: "Resolving secure domain handshake tunnels...", duration: 2300, scale: 88, pitch: 780 },
            { txt: "Redirecting page location to youtube.com...", duration: 3000, scale: 100, pitch: 900 }
        ];

        function runLoaderPipeline() {
            pipeEvents.forEach(step => {
                setTimeout(() => {
                    loaderStatus.textContent = step.txt;
                    progressBar.style.width = `${step.scale}%`;
                    playSynthPitch(step.pitch, 0.15, 'triangle');
                    
                    if (step.scale === 100) {
                        setTimeout(() => {
                            window.location.href = "https://www.youtube.com";
                        }, 500);
                    }
                }, step.duration);
            });
        }
    </script>
</body>
</html>
