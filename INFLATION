                    <i id="monolithIcon" class="fa-solid fa-expand text-base transition-transform duration-500"></i>
                </div>

                <h1 class="text-xs font-semibold tracking-widest text-neutral-700 dark:text-neutral-300 uppercase mb-2">Monolithic Core</h1>
                <p class="text-xs text-neutral-400 dark:text-neutral-500 mb-8 max-w-[240px] leading-relaxed">Hover to charge engines.<br>Click to transition outer systems.</p>

                <!-- The Core Target Action Button -->
                <button id="warpButton" class="relative group/btn w-60 h-14 overflow-hidden rounded-xl border border-neutral-800 dark:border-neutral-200 bg-neutral-900 dark:bg-neutral-50 text-white dark:text-neutral-900 font-medium tracking-wide text-xs uppercase shadow-[0_4px_20px_rgba(0,0,0,0.15)] dark:shadow-[0_4px_25px_rgba(255,255,255,0.08)] transform transition-all duration-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.25)] dark:hover:shadow-[0_8px_30px_rgba(255,255,255,0.15)] focus:outline-none focus:ring-1 focus:ring-neutral-400 active:scale-95">
                    
                    <!-- Monotone Inner liquid visual transition morph -->
