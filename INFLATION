            <!-- Parameters Sliders -->
            <div class="space-y-6">
                <!-- Particle Count -->
                <div class="space-y-2">
                    <div class="flex justify-between text-[11px] font-medium">
                        <span class="text-neutral-500">Star Density</span>
                        <span id="particleVal" class="font-mono text-neutral-400">150</span>
                    </div>
                    <input type="range" id="particleSlider" min="50" max="400" value="150" class="w-full accent-neutral-800 dark:accent-neutral-200 bg-neutral-200 dark:bg-neutral-800 h-1 rounded-lg appearance-none cursor-pointer">
                </div>

                <!-- Idle Speed -->
                <div class="space-y-2">
                    <div class="flex justify-between text-[11px] font-medium">
                        <span class="text-neutral-500">Idle Warp Speed</span>
                        <span id="idleSpeedVal" class="font-mono text-neutral-400">0.4</span>
