                </div>
            </div>

            <!-- Mock Page loading space body -->
            <div class="w-full bg-white dark:bg-neutral-950 border-x border-b border-neutral-200 dark:border-neutral-800 rounded-b-xl p-12 flex flex-col items-center justify-center space-y-8 relative overflow-hidden shadow-2xl">
                
                <!-- Orbiting loader visual ring -->
                <div class="relative w-20 h-20">
                    <div class="absolute inset-0 rounded-full border-4 border-neutral-100 dark:border-neutral-900"></div>
                    <div class="absolute inset-0 rounded-full border-t-4 border-neutral-800 dark:border-white animate-spin"></div>
                    <div class="absolute inset-4 rounded-full border-2 border-dashed border-neutral-200 dark:border-neutral-800 animate-pulse"></div>
                </div>

                <!-- Live Dynamic terminal diagnostics log -->
